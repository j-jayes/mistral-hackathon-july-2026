# Velib Parking App - Environment Configuration

# Mistral API Configuration
# Get your API keys from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_VOX_API_KEY=your_mistral_vox_api_key_here

# Mistral API Endpoints (override if needed)
MISTRAL_API_URL=https://api.mistral.ai/v1
MISTRAL_VOX_API_URL=https://api.mistral.ai/v1/vox

# App Configuration
DEBUG=true
APP_NAME="Velib Parking Guide"

# Single-container serving (docker compose / Cloud Run): FastAPI serves the
# built SPA. PORT is provided by Cloud Run (8080); compose sets it too.
SERVE_FRONTEND=false
# PORT=8080

# Backend Configuration
BACKEND_HOST=localhost
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# CORS Configuration. Comma-separated origins, or "*" for all (same-origin
# single-container deploys don't need CORS, so "*" is fine there).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting (requests per minute)
RATE_LIMIT=60

# Cache Configuration (in minutes)
STATION_CACHE_MINUTES=5

# Velib API (if using official API)
VELIB_API_URL=https://api.velib-metropole.fr/gbfs
VELIB_API_KEY=

# Google Geocoding API (address -> coordinates). Without a key the backend
# falls back to Paris center. Create a key restricted to the Geocoding API:
#   https://console.cloud.google.com/apis/credentials
GEOCODING_API_KEY=
GEOCODING_API_URL=https://maps.googleapis.com/maps/api/geocode/json

# Database (if persisting data)
DATABASE_URL=sqlite:///./velib_app.db