# Controls what `gcloud builds submit` uploads. Keep it small and secret-free.
# (Without this file, gcloud falls back to .gitignore.)
.git
.gitignore
**/node_modules
**/.venv
.venv
**/__pycache__
**/*.pyc
frontend/build
frontend/dist
dist
build

# Local env / secrets
.env
**/.env

# Unused alternate prototype + local-only files
src/
presentation/
specs/
.vibe/
run_*.bat
setup_*.bat
fix_specs.py

# Keep these (needed by the build):
!Dockerfile
!cloudbuild.yaml
!backend/**
!frontend/**
