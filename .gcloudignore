# Controls what `gcloud builds submit` uploads. Keep it small and secret-free.
# (Without this file, gcloud falls back to .gitignore.)
.git
.gitignore
**/node_modules
**/.venv
.venv
**/__pycache__
**/*.pyc
frontend/build
frontend/dist
dist
build

# Local env / secrets
.env
**/.env

# Unused alternate prototype + local-only files (not needed to build the image)
src/
presentation/
docs/
specs/
.vibe/
node_modules/
run_*.bat
setup_*.bat
fix_specs.py
# NOTE: no "!frontend/**" negation here — it would re-include frontend/node_modules
# and balloon the upload. backend/ and frontend/ source are included by default.
